{  
    "name": "project-name",  
    "description": "A short description of the project",  
    "require": {  
        "php": "^7.3|^8.0",  
        "laravel/framework": "^8.0"  
    },  
    "autoload": {  
        "psr-4": {  
            "App\\": "app/"  
        }  
    },  
    "scripts": {  
        "post-autoload-dump": [  
            "Illuminate\Foundation\ComposerScripts::postAutoloadDump",  
            "php artisan package:discover --ansi"  
        ]  
    },  
    "config": {  
        "optimize-autoloader": true,  
        "sort-packages": true  
    },  
    "minimum-stability": "dev",  
    "prefer-stable": true  
}